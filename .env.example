# GitHub OAuth App
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# next-auth secret (generate with: openssl rand -hex 32)
AUTH_SECRET=your_nextauth_secret

# GitHub Personal Access Token for Gist storage (needs gist scope)
GITHUB_GIST_TOKEN=your_github_pat_with_gist_scope

# Base path (only for GitHub Pages deployment)
# NEXT_PUBLIC_BASE_PATH=/cp-handbook
